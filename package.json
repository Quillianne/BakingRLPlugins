{
  "name": "bakingrl-plugins",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "cast-package",
    "deja-vu",
    "player-streak",
    "obs-gateway",
    "poc-simple-node",
    "poc-webview-settings",
    "poc-sidecar",
    "poc-overlay-studio",
    "poc-visual-pack",
    "poc-content-pack"
  ],
  "scripts": {
    "create": "create-bakingrl-plugin",
    "build": "npm run build --workspaces --if-present",
    "check": "npm run check --workspaces --if-present",
    "validate": "npm run validate --workspaces --if-present",
    "validate:poc-chain": "node scripts/validate-poc-chain.mjs",
    "validate:runtime-poc": "node scripts/smoke-runtime-poc.mjs",
    "validate:local-install": "node scripts/validate-local-install.mjs",
    "validate:local-sdk-pack": "node scripts/validate-local-sdk-pack.mjs",
    "pack": "npm run pack --workspaces --if-present",
    "install:local": "npm run install:local --workspaces --if-present"
  },
  "devDependencies": {
    "@bakingrl/create-plugin": "2.2.0"
  },
  "license": "MIT"
}
