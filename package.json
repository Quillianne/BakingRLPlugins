{
  "name": "bakingrl-plugins",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "stats-extended",
    "layout-studio",
    "broadcast-visuals",
    "deja-vu",
    "player-streak",
    "obs-gateway",
    "poc-simple-node",
    "poc-webview-settings",
    "poc-sidecar",
    "poc-overlay-studio",
    "poc-visual-pack",
    "poc-content-pack"
  ],
  "scripts": {
    "create": "create-bakingrl-plugin",
    "build": "npm run build --workspaces --if-present",
    "check": "npm run check --workspaces --if-present",
    "validate": "npm run validate --workspaces --if-present && npm run validate:product-chain && npm run validate:obs-gateway",
    "validate:poc-chain": "node scripts/validate-poc-chain.mjs",
    "validate:product-chain": "node scripts/validate-product-chain.mjs",
    "validate:obs-gateway": "node scripts/validate-obs-gateway.mjs",
    "validate:release-obs": "node scripts/validate-obs-release-artifact.mjs",
    "validate:release-portable": "node scripts/validate-portable-release-artifacts.mjs",
    "validate:listing": "node scripts/validate-listings.mjs",
    "validate:runtime-poc": "node scripts/smoke-runtime-poc.mjs",
    "validate:local-install": "node scripts/validate-local-install.mjs",
    "validate:local-sdk-pack": "node scripts/validate-local-sdk-pack.mjs",
    "pack": "npm run pack --workspaces --if-present",
    "pack:release": "node scripts/release-workspaces.mjs pack",
    "build:release-portable": "node scripts/release-workspaces.mjs build --portable-only",
    "pack:release-portable": "node scripts/release-workspaces.mjs pack --portable-only --sign-from-env",
    "pack:release-obs": "node scripts/release-workspaces.mjs pack --workspace obs-gateway --sign-from-env",
    "stage:release-obs": "node scripts/stage-obs-bundle.mjs",
    "install:local": "npm run install:local --workspaces --if-present"
  },
  "devDependencies": {
    "@bakingrl/create-plugin": "2.3.0"
  },
  "license": "MIT"
}
