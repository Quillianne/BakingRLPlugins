{
  "schema": "bakingrl.plugin/2",
  "id": "com.bakingrl.bo-tracker",
  "name": "BO Tracker",
  "version": "1.0.0",
  "author": "BakingRL",
  "exports": {
    "visuals": {
      "controlPanel": {
        "entry": "dist/visuals/control-panel.js",
        "defaultSize": [1200, 740],
        "settings": "src/visuals/control-panel/settings.schema.json"
      }
    },
    "services": {
      "boTracker": {
        "entry": "dist/services/bo-tracker.js",
        "methods": [
          "snapshot",
          "configure",
          "start",
          "stop",
          "adjustScore",
          "award",
          "undo",
          "reset"
        ],
        "schema": "src/services/bo-tracker/methods.schema.json"
      }
    },
    "pages": {
      "control": {
        "path": "pages/control.json",
        "title": "BO Tracker Control",
        "description": "Configure team names, BO format, tracking state, and series score."
      }
    }
  },
  "imports": {
    "components": [],
    "services": []
  },
  "permissions": {
    "bus": {
      "read": [
        "MatchCreated",
        "MatchInitialized",
        "RoundStarted",
        "MatchEnded",
        "plugin.com.bakingrl.bo-tracker.state"
      ],
      "publish": [
        "plugin.com.bakingrl.bo-tracker.*"
      ]
    },
    "registry": {
      "read": [],
      "write": [
        "plugin.com.bakingrl.bo-tracker.*"
      ]
    },
    "network": {
      "http": [],
      "websocket": []
    },
    "storage": [
      "plugin://self/*"
    ]
  }
}
