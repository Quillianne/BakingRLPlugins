{
  "schemaVersion": "bakingrl.plugin/4",
  "bakingrlApi": "2.3.0",
  "permissions": {
    "bus": {
      "read": [
        "UpdateState",
        "MatchCreated",
        "MatchInitialized",
        "MatchDestroyed",
        "plugin.com.bakingrl.deja-vu.state"
      ],
      "publish": [
        "plugin.com.bakingrl.deja-vu.state"
      ]
    },
    "registry": {
      "read": [
        "plugin.com.bakingrl.deja-vu.state"
      ],
      "write": [
        "plugin.com.bakingrl.deja-vu.state"
      ]
    },
    "network": {
      "http": [],
      "websocket": [],
      "listen": []
    },
    "storage": {
      "read": [
        "deja-vu-state.json"
      ],
      "write": [
        "deja-vu-state.json"
      ]
    }
  },
  "id": "com.bakingrl.deja-vu",
  "name": "Deja Vu",
  "version": "2.0.0",
  "author": "BakingRL",
  "dependencies": [
    {
      "packageId": "bakingrl.layout-studio",
      "version": "^1.0.0"
    }
  ],
  "runtime": {
    "node": {
      "entry": "dist/extension/index.js"
    },
    "sidecars": []
  },
  "contributes": {
    "services": [
      {
        "id": "dejaVu",
        "runtime": "node",
        "methods": [
          "snapshot",
          "reset"
        ],
        "schema": "src/services/deja-vu/methods.schema.json"
      }
    ],
    "settings": {
      "schema": "src/settings.schema.json"
    },
    "resources": [
      {
        "id": "dejaVu",
        "path": "dist/visuals/deja-vu.js",
        "type": "application/javascript",
        "visibility": "public",
        "metadata": {
          "role": "renderer-module",
          "moduleFormat": "esm",
          "defaultSize": [
            300,
            100
          ],
          "settingsSchema": "src/visuals/deja-vu/settings.schema.json"
        }
      }
    ],
    "contributions": [
      {
        "id": "deja-vu",
        "target": "bakingrl.layout-studio/visual",
        "kind": "visual",
        "title": "Deja Vu",
        "description": "Highlights repeated player and team matchups.",
        "dataSchema": "src/contracts/layout-visual-contribution.schema.json",
        "resources": ["dejaVu"],
        "metadata": {
          "category": "Match",
          "defaultSize": [300, 100],
          "remoteCompatible": true,
          "renderer": {
            "kind": "resource-module",
            "resource": "dejaVu",
            "moduleFormat": "esm",
            "export": "default"
          }
        }
      }
    ]
  }
}
