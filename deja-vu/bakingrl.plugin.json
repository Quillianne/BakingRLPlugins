{
  "schemaVersion": "bakingrl.plugin/4",
  "bakingrlApi": "2.0.0",
  "id": "com.bakingrl.deja-vu",
  "name": "Deja Vu",
  "version": "1.0.4",
  "author": "BakingRL",
  "runtime": {
    "node": {
      "entry": "dist/extension/index.js"
    },
    "sidecars": []
  },
  "contributes": {
    "visuals": [
      {
        "id": "dejaVu",
        "entry": "dist/visuals/deja-vu.js",
        "defaultSize": [300, 100],
        "instanceSettings": "src/visuals/deja-vu/settings.schema.json"
      }
    ],
    "services": [
      {
        "id": "dejaVu",
        "runtime": "node",
        "methods": ["snapshot", "reset"],
        "schema": "src/services/deja-vu/methods.schema.json"
      }
    ],
    "settings": {
      "schema": "src/settings.schema.json"
    }
  }
}
