{
  "schema": "bakingrl.plugin/2",
  "id": "com.bakingrl.deja-vu",
  "name": "Deja Vu",
  "version": "1.0.3",
  "author": "BakingRL",
  "compatibility": {
    "runtimeApi": "0.4.0",
    "sdk": "0.4.0"
  },
  "settings": "src/settings.schema.json",
  "exports": {
    "visuals": {
      "dejaVu": {
        "entry": "dist/visuals/deja-vu.js",
        "defaultSize": [300, 100],
        "settings": "src/visuals/deja-vu/settings.schema.json"
      }
    },
    "services": {
      "dejaVu": {
        "entry": "dist/services/deja-vu.js",
        "methods": ["snapshot", "reset"],
        "schema": "src/services/deja-vu/methods.schema.json"
      }
    }
  },
  "imports": {
    "components": [],
    "services": []
  },
  "permissions": {
    "bus": {
      "read": [
        "UpdateState",
        "MatchCreated",
        "MatchInitialized",
        "MatchDestroyed",
        "plugin.com.bakingrl.deja-vu.state"
      ],
      "publish": [
        "plugin.com.bakingrl.deja-vu.*"
      ]
    },
    "registry": {
      "read": [
        "plugin.com.bakingrl.deja-vu.*"
      ],
      "write": [
        "plugin.com.bakingrl.deja-vu.*"
      ]
    },
    "network": {
      "http": [],
      "websocket": []
    },
    "storage": [
      "plugin://self/*"
    ]
  }
}
