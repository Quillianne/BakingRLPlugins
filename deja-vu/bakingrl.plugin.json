{
  "schemaVersion": "bakingrl.plugin/4",
  "bakingrlApi": "2.3.0",
  "permissions": {
    "bus": {
      "read": [
        "UpdateState",
        "MatchCreated",
        "MatchInitialized",
        "MatchDestroyed",
        "plugin.com.bakingrl.deja-vu.state"
      ],
      "publish": [
        "plugin.com.bakingrl.deja-vu.state"
      ]
    },
    "registry": {
      "read": [
        "plugin.com.bakingrl.deja-vu.state"
      ],
      "write": [
        "plugin.com.bakingrl.deja-vu.state"
      ]
    },
    "network": {
      "http": [],
      "websocket": [],
      "listen": []
    },
    "storage": {
      "read": [
        "deja-vu-state.json"
      ],
      "write": [
        "deja-vu-state.json"
      ]
    }
  },
  "id": "com.bakingrl.deja-vu",
  "name": "Deja Vu",
  "version": "1.0.5",
  "author": "BakingRL",
  "runtime": {
    "node": {
      "entry": "dist/extension/index.js"
    },
    "sidecars": []
  },
  "contributes": {
    "services": [
      {
        "id": "dejaVu",
        "runtime": "node",
        "methods": [
          "snapshot",
          "reset"
        ],
        "schema": "src/services/deja-vu/methods.schema.json"
      }
    ],
    "settings": {
      "schema": "src/settings.schema.json"
    },
    "resources": [
      {
        "id": "dejaVu",
        "path": "dist/visuals/deja-vu.js",
        "type": "application/javascript",
        "visibility": "public",
        "metadata": {
          "role": "renderer-module",
          "moduleFormat": "esm",
          "defaultSize": [
            300,
            100
          ],
          "settingsSchema": "src/visuals/deja-vu/settings.schema.json"
        }
      }
    ]
  }
}
