{
  "type": "object",
  "title": "BO Control Settings",
  "properties": {
    "title": {
      "type": "string",
      "title": "Titre",
      "default": "Régie de match"
    },
    "subtitle": {
      "type": "string",
      "title": "Sous-titre",
      "default": "Préparation et direct"
    },
    "defaultBestOf": {
      "type": "integer",
      "title": "Format de BO par défaut",
      "default": 5,
      "oneOf": [
        { "const": 1, "title": "BO1" },
        { "const": 3, "title": "BO3" },
        { "const": 5, "title": "BO5" },
        { "const": 7, "title": "BO7" }
      ]
    },
    "showHistory": {
      "type": "boolean",
      "title": "Afficher l’historique des matchs",
      "default": true
    },
    "historyLimit": {
      "type": "integer",
      "title": "Nombre de matchs dans l’historique",
      "default": 6,
      "minimum": 0,
      "maximum": 12
    }
  }
}
