{
  "schemaVersion": "bakingrl.plugin/4",
  "bakingrlApi": "2.4.0",
  "permissions": {
    "bus": {
      "read": [
        "UpdateState"
      ],
      "publish": []
    },
    "registry": {
      "read": [],
      "write": []
    },
    "network": {
      "http": [],
      "websocket": [],
      "listen": []
    },
    "storage": {
      "read": [
        "runtime-state.json"
      ],
      "write": [
        "runtime-state.json"
      ]
    }
  },
  "id": "bakingrl.poc-simple-node",
  "name": "POC Simple Node",
  "version": "1.0.0",
  "author": "BakingRL",
  "presentation": {
    "categories": ["development"]
  },
  "runtime": {
    "node": {
      "entry": "dist/extension/index.js"
    },
    "sidecars": []
  },
  "contributes": {
    "services": [
      {
        "id": "pocSimpleNode",
        "runtime": "node",
        "methods": [
          "ping",
          "snapshot",
          "debugState"
        ],
        "schema": "src/services/poc-simple-node/methods.schema.json"
      }
    ],
    "settings": {
      "schema": "src/settings.schema.json"
    }
  }
}
