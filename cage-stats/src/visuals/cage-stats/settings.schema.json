{
  "type": "object",
  "title": "Cage Stats Settings",
  "properties": {
    "scope": {
      "type": "string",
      "title": "Scope",
      "default": "bothCages",
      "oneOf": [
        { "const": "bothCages", "title": "Both Cages" },
        { "const": "teamDefense", "title": "Team Defense" },
        { "const": "playerSaves", "title": "Player Saves" },
        { "const": "playerOffense", "title": "Player Offense" }
      ]
    },
    "teamNum": {
      "type": "integer",
      "title": "Team Number",
      "default": 0,
      "minimum": 0,
      "maximum": 1
    },
    "playerName": {
      "type": "string",
      "title": "Player Name",
      "default": ""
    },
    "title": {
      "type": "string",
      "title": "Title",
      "default": ""
    },
    "metrics": {
      "type": "array",
      "title": "Metrics",
      "default": ["goal", "crossbar", "save"],
      "items": {
        "type": "string",
        "oneOf": [
          { "const": "goal", "title": "Goals" },
          { "const": "crossbar", "title": "Crossbars" },
          { "const": "save", "title": "Saves" }
        ]
      }
    },
    "showMap": {
      "type": "boolean",
      "title": "Show Map",
      "default": true
    },
    "showControls": {
      "type": "boolean",
      "title": "Show Demo Controls",
      "default": false
    },
    "showEvents": {
      "type": "boolean",
      "title": "Show Events",
      "default": true
    },
    "maxEvents": {
      "type": "integer",
      "title": "Max Events",
      "default": 8,
      "minimum": 0,
      "maximum": 20
    }
  }
}
