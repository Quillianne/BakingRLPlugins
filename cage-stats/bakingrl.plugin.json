{
  "schema": "bakingrl.plugin/2",
  "id": "com.bakingrl.cage-stats",
  "name": "Cage Stats",
  "version": "1.0.0",
  "author": "BakingRL",
  "compatibility": {
    "runtimeApi": "0.4.0",
    "sdk": "0.4.0"
  },
  "exports": {
    "components": {
      "cageMap": {
        "entry": "dist/components/cage-map.js",
        "props": "src/components/cage-map/props.schema.json"
      }
    },
    "visuals": {
      "cageStats": {
        "entry": "dist/visuals/cage-stats.js",
        "defaultSize": [760, 240],
        "settings": "src/visuals/cage-stats/settings.schema.json"
      }
    },
    "services": {
      "cageStats": {
        "entry": "dist/services/cage-stats.js",
        "methods": ["snapshot", "configure", "reset"],
        "schema": "src/services/cage-stats/methods.schema.json"
      }
    },
    "pages": {
      "demo": {
        "path": "pages/demo.json",
        "title": "Cage Stats Demo",
        "description": "Interactive demo page for trying Cage Stats scopes and display options."
      }
    }
  },
  "imports": {
    "components": [],
    "services": []
  },
  "permissions": {
    "bus": {
      "read": [
        "UpdateState",
        "BallHit",
        "CountdownBegin",
        "CrossbarHit",
        "GoalScored",
        "MatchCreated",
        "MatchInitialized",
        "StatfeedEvent",
        "plugin.com.bakingrl.cage-stats.state"
      ],
      "publish": [
        "plugin.com.bakingrl.cage-stats.*"
      ]
    },
    "registry": {
      "read": [
        "plugin.com.bakingrl.cage-stats.*"
      ],
      "write": [
        "plugin.com.bakingrl.cage-stats.*"
      ]
    },
    "network": {
      "http": [],
      "websocket": []
    },
    "storage": [
      "plugin://self/*"
    ]
  }
}
