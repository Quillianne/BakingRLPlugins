{
  "schemaVersion": "bakingrl.plugin/4",
  "bakingrlApi": "2.0.0",
  "id": "com.bakingrl.cast-package",
  "name": "Cast Package",
  "version": "1.0.5",
  "author": "BakingRL",
  "runtime": {
    "node": {
      "entry": "dist/extension/index.js"
    },
    "sidecars": []
  },
  "contributes": {
    "visuals": [
      {
        "id": "boControl",
        "entry": "dist/visuals/bo-control.js",
        "defaultSize": [1200, 900],
        "instanceSettings": "src/visuals/control-panel/settings.schema.json"
      },
      {
        "id": "scoreboard",
        "entry": "dist/visuals/scoreboard.js",
        "defaultSize": [760, 128],
        "instanceSettings": "src/visuals/scoreboard/settings.schema.json"
      },
      {
        "id": "goalAnimation",
        "entry": "dist/visuals/goal-animation.js",
        "defaultSize": [1920, 1080],
        "instanceSettings": "src/visuals/goal/settings.schema.json"
      },
      {
        "id": "victoryAnimation",
        "entry": "dist/visuals/victory-animation.js",
        "defaultSize": [1920, 1080],
        "instanceSettings": "src/visuals/victory/settings.schema.json"
      },
      {
        "id": "playerBoost",
        "entry": "dist/visuals/player-boost.js",
        "defaultSize": [220, 120],
        "instanceSettings": "src/visuals/player-boost/settings.schema.json"
      },
      {
        "id": "playerStatLive",
        "entry": "dist/visuals/player-stat-live.js",
        "defaultSize": [360, 110],
        "instanceSettings": "src/visuals/player-stats/settings.schema.json"
      },
      {
        "id": "teamPreviewLive",
        "entry": "dist/visuals/team-preview-live.js",
        "defaultSize": [420, 170],
        "instanceSettings": "src/visuals/team-events/settings.schema.json"
      },
      {
        "id": "cageStats",
        "entry": "dist/visuals/cage-stats.js",
        "defaultSize": [760, 260],
        "instanceSettings": "src/visuals/cage-stats/settings.schema.json"
      },
      {
        "id": "statistics",
        "entry": "dist/visuals/statistics.js",
        "defaultSize": [900, 420],
        "instanceSettings": "src/visuals/statistics/settings.schema.json"
      },
      {
        "id": "fullscreenStats",
        "entry": "dist/visuals/fullscreen-stats.js",
        "defaultSize": [1920, 1080],
        "instanceSettings": "src/visuals/fullscreen-stats/settings.schema.json"
      }
    ],
    "services": [
      {
        "id": "boTracker",
        "runtime": "node",
        "methods": [
          "snapshot",
          "configure",
          "start",
          "stop",
          "adjustScore",
          "award",
          "undo",
          "reset"
        ],
        "schema": "src/services/bo-tracker/methods.schema.json"
      },
      {
        "id": "gameSequence",
        "runtime": "node",
        "methods": [
          "snapshot",
          "reset"
        ],
        "schema": "src/services/game-sequence/methods.schema.json"
      },
      {
        "id": "playerStatsTracker",
        "runtime": "node",
        "methods": [
          "snapshot",
          "reset"
        ],
        "schema": "src/services/player-stats/methods.schema.json"
      },
      {
        "id": "cageStats",
        "runtime": "node",
        "methods": [
          "snapshot",
          "configure",
          "reset"
        ],
        "schema": "src/services/cage-stats/methods.schema.json"
      },
      {
        "id": "regieController",
        "runtime": "node",
        "methods": [
          "trigger",
          "clear",
          "snapshot"
        ],
        "schema": "src/services/regie-controller/methods.schema.json"
      }
    ]
  }
}
