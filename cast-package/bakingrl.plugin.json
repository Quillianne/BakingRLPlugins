{
  "schemaVersion": "bakingrl.plugin/4",
  "bakingrlApi": "2.2.0",
  "id": "com.bakingrl.cast-package",
  "name": "Cast Package",
  "version": "1.0.5",
  "author": "BakingRL",
  "runtime": {
    "node": {
      "entry": "dist/extension/index.js"
    },
    "sidecars": []
  },
  "contributes": {
    "services": [
      {
        "id": "boTracker",
        "runtime": "node",
        "methods": [
          "snapshot",
          "configure",
          "start",
          "stop",
          "adjustScore",
          "award",
          "undo",
          "reset"
        ],
        "schema": "src/services/bo-tracker/methods.schema.json"
      },
      {
        "id": "gameSequence",
        "runtime": "node",
        "methods": [
          "snapshot",
          "reset"
        ],
        "schema": "src/services/game-sequence/methods.schema.json"
      },
      {
        "id": "playerStatsTracker",
        "runtime": "node",
        "methods": [
          "snapshot",
          "reset"
        ],
        "schema": "src/services/player-stats/methods.schema.json"
      },
      {
        "id": "cageStats",
        "runtime": "node",
        "methods": [
          "snapshot",
          "configure",
          "reset"
        ],
        "schema": "src/services/cage-stats/methods.schema.json"
      },
      {
        "id": "regieController",
        "runtime": "node",
        "methods": [
          "trigger",
          "clear",
          "snapshot"
        ],
        "schema": "src/services/regie-controller/methods.schema.json"
      }
    ],
    "resources": [
      {
        "id": "boControl",
        "path": "dist/visuals/bo-control.js",
        "type": "application/javascript",
        "visibility": "public",
        "metadata": {
          "role": "renderer-module",
          "moduleFormat": "esm",
          "defaultSize": [
            1200,
            900
          ],
          "settingsSchema": "src/visuals/control-panel/settings.schema.json"
        }
      },
      {
        "id": "scoreboard",
        "path": "dist/visuals/scoreboard.js",
        "type": "application/javascript",
        "visibility": "public",
        "metadata": {
          "role": "renderer-module",
          "moduleFormat": "esm",
          "defaultSize": [
            760,
            128
          ],
          "settingsSchema": "src/visuals/scoreboard/settings.schema.json"
        }
      },
      {
        "id": "goalAnimation",
        "path": "dist/visuals/goal-animation.js",
        "type": "application/javascript",
        "visibility": "public",
        "metadata": {
          "role": "renderer-module",
          "moduleFormat": "esm",
          "defaultSize": [
            1920,
            1080
          ],
          "settingsSchema": "src/visuals/goal/settings.schema.json"
        }
      },
      {
        "id": "victoryAnimation",
        "path": "dist/visuals/victory-animation.js",
        "type": "application/javascript",
        "visibility": "public",
        "metadata": {
          "role": "renderer-module",
          "moduleFormat": "esm",
          "defaultSize": [
            1920,
            1080
          ],
          "settingsSchema": "src/visuals/victory/settings.schema.json"
        }
      },
      {
        "id": "playerBoost",
        "path": "dist/visuals/player-boost.js",
        "type": "application/javascript",
        "visibility": "public",
        "metadata": {
          "role": "renderer-module",
          "moduleFormat": "esm",
          "defaultSize": [
            220,
            120
          ],
          "settingsSchema": "src/visuals/player-boost/settings.schema.json"
        }
      },
      {
        "id": "playerStatLive",
        "path": "dist/visuals/player-stat-live.js",
        "type": "application/javascript",
        "visibility": "public",
        "metadata": {
          "role": "renderer-module",
          "moduleFormat": "esm",
          "defaultSize": [
            360,
            110
          ],
          "settingsSchema": "src/visuals/player-stats/settings.schema.json"
        }
      },
      {
        "id": "teamPreviewLive",
        "path": "dist/visuals/team-preview-live.js",
        "type": "application/javascript",
        "visibility": "public",
        "metadata": {
          "role": "renderer-module",
          "moduleFormat": "esm",
          "defaultSize": [
            420,
            170
          ],
          "settingsSchema": "src/visuals/team-events/settings.schema.json"
        }
      },
      {
        "id": "cageStats",
        "path": "dist/visuals/cage-stats.js",
        "type": "application/javascript",
        "visibility": "public",
        "metadata": {
          "role": "renderer-module",
          "moduleFormat": "esm",
          "defaultSize": [
            760,
            260
          ],
          "settingsSchema": "src/visuals/cage-stats/settings.schema.json"
        }
      },
      {
        "id": "statistics",
        "path": "dist/visuals/statistics.js",
        "type": "application/javascript",
        "visibility": "public",
        "metadata": {
          "role": "renderer-module",
          "moduleFormat": "esm",
          "defaultSize": [
            900,
            420
          ],
          "settingsSchema": "src/visuals/statistics/settings.schema.json"
        }
      },
      {
        "id": "fullscreenStats",
        "path": "dist/visuals/fullscreen-stats.js",
        "type": "application/javascript",
        "visibility": "public",
        "metadata": {
          "role": "renderer-module",
          "moduleFormat": "esm",
          "defaultSize": [
            1920,
            1080
          ],
          "settingsSchema": "src/visuals/fullscreen-stats/settings.schema.json"
        }
      }
    ]
  }
}
