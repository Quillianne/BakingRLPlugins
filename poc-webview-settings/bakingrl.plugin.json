{
  "schemaVersion": "bakingrl.plugin/4",
  "bakingrlApi": "2.4.0",
  "permissions": {
    "bus": {
      "read": [],
      "publish": []
    },
    "registry": {
      "read": [],
      "write": []
    },
    "network": {
      "http": [],
      "websocket": [],
      "listen": []
    },
    "storage": {
      "read": [],
      "write": []
    }
  },
  "id": "bakingrl.poc-webview-settings",
  "name": "POC Webview Settings",
  "version": "1.0.0",
  "author": "BakingRL",
  "presentation": {
    "categories": ["development"],
    "primaryAction": {
      "kind": "webview",
      "target": "settings"
    }
  },
  "runtime": {
    "node": {
      "entry": "dist/extension/index.js"
    },
    "sidecars": []
  },
  "contributes": {
    "commands": [
      {
        "id": "openSettings",
        "title": "Open POC Settings",
        "category": "POC"
      }
    ],
    "services": [
      {
        "id": "pocWebviewSettings",
        "runtime": "node",
        "methods": [
          "openSettings",
          "settingsSnapshot"
        ],
        "schema": "src/services/poc-webview-settings/methods.schema.json"
      }
    ],
    "settings": {
      "schema": "src/settings.schema.json"
    },
    "webviews": [
      {
        "id": "settings",
        "entry": "dist/webviews/settings.js",
        "title": "POC Settings",
        "kind": "settings",
        "defaultSize": [
          720,
          520
        ]
      }
    ]
  }
}
