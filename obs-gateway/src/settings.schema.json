{
  "type": "object",
  "title": "OBS Gateway",
  "properties": {
    "enabled": {
      "type": "boolean",
      "title": "Enable OBS Gateway",
      "default": true
    },
    "listenAddress": {
      "type": "string",
      "title": "Listen Address",
      "default": "127.0.0.1"
    },
    "listenPort": {
      "type": "integer",
      "title": "Listen Port",
      "minimum": 1024,
      "maximum": 65535,
      "default": 17844
    },
    "routePrefix": {
      "type": "string",
      "title": "Overlay Route Prefix",
      "default": "/overlay"
    },
    "streamPath": {
      "type": "string",
      "title": "Stream Overlay Path",
      "default": "/stream"
    },
    "streamLayoutId": {
      "type": "string",
      "title": "Stream Layout",
      "default": ""
    },
    "secretKeyRef": {
      "type": "string",
      "title": "Host secret reference used for OBS authentication",
      "description": "Fixed reference to the declared host-owned access token. This is a key name, never the secret value.",
      "default": "obs.gateway.accessToken"
    },
    "obs.gateway.accessToken": {
      "type": "string",
      "title": "OBS Gateway access token",
      "description": "Stored exclusively in the BakingRL host secret vault. Required for network access and optional for localhost.",
      "format": "password",
      "x-bakingrl-secret": true
    },
    "requireToken": {
      "type": "boolean",
      "title": "Require token on local URLs",
      "description": "Non-local bind addresses require the configured token automatically. Enable this to also require it for local OBS URLs.",
      "default": false
    },
    "allowedOrigins": {
      "type": "array",
      "title": "Allowed CORS Origins",
      "items": {
        "type": "string"
      },
      "default": ["http://localhost", "http://127.0.0.1"]
    },
    "heartbeatMs": {
      "type": "integer",
      "title": "Heartbeat interval (ms)",
      "minimum": 1000,
      "default": 15000
    }
  }
}
