{
  "schemaVersion": "bakingrl.plugin/4",
  "bakingrlApi": "2.3.0",
  "permissions": {
    "bus": {
      "read": [
        "plugin.bakingrl.layout-studio.changed"
      ],
      "publish": []
    },
    "registry": {
      "read": [],
      "write": []
    },
    "network": {
      "http": [],
      "websocket": [],
      "listen": [
        {
          "transport": "tcp",
          "host": "127.0.0.1",
          "ports": "*"
        }
      ]
    },
    "storage": {
      "read": [],
      "write": []
    }
  },
  "id": "bakingrl.obs-gateway",
  "name": "OBS Gateway",
  "version": "2.0.1",
  "author": "BakingRL",
  "dependencies": [
    {
      "packageId": "bakingrl.layout-studio",
      "version": "^1.0.0"
    }
  ],
  "runtime": {
    "node": {
      "entry": "dist/extension/index.js"
    },
    "sidecars": [
      {
        "id": "gateway",
        "bin": "bin/obs-gateway-sidecar",
        "protocol": "jsonrpc-stdio",
        "activation": "onStartup"
      }
    ]
  },
  "contributes": {
    "services": [
      {
        "id": "obsGateway",
        "runtime": "node",
        "methods": [
          "snapshot",
          "configure",
          "setConnectionState",
          "refreshHostData",
          "updateHostData"
        ],
        "schema": "src/services/obs-gateway/methods.schema.json"
      }
    ],
    "settings": {
      "schema": "src/settings.schema.json",
      "ui": "obsGatewayConfig"
    },
    "webviews": [
      {
        "id": "obsGatewayConfig",
        "entry": "dist/webviews/config.js",
        "title": "OBS Gateway Settings",
        "kind": "settings",
        "defaultSize": [
          980,
          720
        ]
      }
    ]
  }
}
