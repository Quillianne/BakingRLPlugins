{
  "schemaVersion": "bakingrl.plugin/4",
  "bakingrlApi": "2.0.0",
  "id": "bakingrl.obs-gateway",
  "name": "OBS Gateway",
  "version": "1.0.5",
  "author": "BakingRL",
  "runtime": {
    "node": {
      "entry": "dist/extension/index.js"
    },
    "sidecars": [
      {
        "id": "gateway",
        "bin": "bin/obs-gateway-sidecar",
        "protocol": "jsonrpc-stdio",
        "activation": "onStartup"
      }
    ]
  },
  "contributes": {
    "visuals": [
      {
        "id": "obsGatewayConfig",
        "kind": "config",
        "entry": "dist/visuals/config.js",
        "defaultSize": [980, 720]
      }
    ],
    "services": [
      {
        "id": "obsGateway",
        "runtime": "node",
        "methods": ["snapshot", "configure", "setConnectionState", "refreshHostData", "updateHostData"],
        "schema": "src/services/obs-gateway/methods.schema.json"
      }
    ],
    "settings": {
      "schema": "src/settings.schema.json",
      "ui": "obsGatewayConfig"
    }
  }
}
