{
  "name": "@bakingrl-plugins/obs-gateway",
  "version": "2.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:sidecar && vite build",
    "build:sidecar": "cargo build --manifest-path sidecar/Cargo.toml --target-dir ../.cargo-target/obs-gateway --release && node scripts/copy-sidecar.mjs",
    "check": "tsc -p tsconfig.json --noEmit && cargo check --manifest-path sidecar/Cargo.toml --target-dir ../.cargo-target/obs-gateway",
    "validate": "bakingrl-plugin validate && node ../scripts/validate-obs-gateway.mjs",
    "pack": "bakingrl-plugin pack",
    "install:local": "bakingrl-plugin install-local"
  },
  "dependencies": {
    "@bakingrl/plugin-sdk": "2.3.1"
  },
  "devDependencies": {
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
