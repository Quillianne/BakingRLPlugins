{
  "schemaVersion": "bakingrl.plugin/4",
  "bakingrlApi": "2.4.0",
  "permissions": {
    "bus": {
      "read": [
        "MatchCreated",
        "MatchInitialized",
        "MatchEnded",
        "MatchDestroyed",
        "plugin.bakingrl.stats-extended.sequence",
        "plugin.bakingrl.stats-extended.player-stats",
        "plugin.com.bakingrl.player-streak.state"
      ],
      "publish": [
        "plugin.com.bakingrl.player-streak.state"
      ]
    },
    "registry": {
      "read": [
        "plugin.bakingrl.stats-extended.sequence",
        "plugin.bakingrl.stats-extended.player-stats",
        "plugin.com.bakingrl.player-streak.state"
      ],
      "write": [
        "plugin.com.bakingrl.player-streak.state"
      ]
    },
    "network": {
      "http": [],
      "websocket": [],
      "listen": []
    },
    "storage": {
      "read": [
        "player-streak-state.json"
      ],
      "write": [
        "player-streak-state.json"
      ]
    }
  },
  "id": "com.bakingrl.player-streak",
  "name": "PlayerStreak",
  "version": "2.0.1",
  "author": "BakingRL",
  "presentation": {
    "categories": ["visuals"]
  },
  "dependencies": [
    {
      "packageId": "bakingrl.stats-extended",
      "version": "^1.0.0"
    },
    {
      "packageId": "bakingrl.layout-studio",
      "version": "^1.0.0"
    }
  ],
  "runtime": {
    "node": {
      "entry": "dist/extension/index.js"
    },
    "sidecars": []
  },
  "contributes": {
    "services": [
      {
        "id": "playerStreak",
        "runtime": "node",
        "methods": [
          "snapshot",
          "reset"
        ],
        "schema": "src/services/player-streak/methods.schema.json"
      }
    ],
    "settings": {
      "schema": "src/settings.schema.json"
    },
    "resources": [
      {
        "id": "playerStreak",
        "path": "dist/visuals/player-streak.js",
        "type": "application/javascript",
        "visibility": "public",
        "metadata": {
          "role": "renderer-module",
          "moduleFormat": "esm",
          "defaultSize": [
            420,
            120
          ],
          "settingsSchema": "src/visuals/player-streak/settings.schema.json"
        }
      }
    ],
    "contributions": [
      {
        "id": "player-streak",
        "target": "bakingrl.layout-studio/visual",
        "kind": "visual",
        "title": "Player streak",
        "description": "Session and global win/loss streak for a selected player.",
        "dataSchema": "src/contracts/layout-visual-contribution.schema.json",
        "resources": ["playerStreak"],
        "metadata": {
          "category": "Players",
          "defaultSize": [420, 120],
          "remoteCompatible": true,
          "renderer": {
            "kind": "resource-module",
            "resource": "playerStreak",
            "moduleFormat": "esm",
            "export": "default"
          }
        }
      }
    ]
  }
}
