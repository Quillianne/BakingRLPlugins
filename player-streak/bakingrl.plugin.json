{
  "schemaVersion": "bakingrl.plugin/4",
  "bakingrlApi": "2.3.0",
  "permissions": {
    "bus": {
      "read": [
        "MatchCreated",
        "MatchInitialized",
        "MatchEnded",
        "MatchDestroyed",
        "plugin.com.bakingrl.cast-package.sequence",
        "plugin.com.bakingrl.cast-package.player-stats",
        "plugin.com.bakingrl.player-streak.state"
      ],
      "publish": [
        "plugin.com.bakingrl.player-streak.state"
      ]
    },
    "registry": {
      "read": [
        "plugin.com.bakingrl.cast-package.sequence",
        "plugin.com.bakingrl.cast-package.player-stats",
        "plugin.com.bakingrl.player-streak.state"
      ],
      "write": [
        "plugin.com.bakingrl.player-streak.state"
      ]
    },
    "network": {
      "http": [],
      "websocket": [],
      "listen": []
    },
    "storage": {
      "read": [
        "player-streak-state.json"
      ],
      "write": [
        "player-streak-state.json"
      ]
    }
  },
  "id": "com.bakingrl.player-streak",
  "name": "PlayerStreak",
  "version": "1.0.5",
  "author": "BakingRL",
  "dependencies": [
    {
      "packageId": "com.bakingrl.cast-package",
      "version": "^1.0.0",
      "optional": true
    }
  ],
  "runtime": {
    "node": {
      "entry": "dist/extension/index.js"
    },
    "sidecars": []
  },
  "contributes": {
    "services": [
      {
        "id": "playerStreak",
        "runtime": "node",
        "methods": [
          "snapshot",
          "reset"
        ],
        "schema": "src/services/player-streak/methods.schema.json"
      }
    ],
    "settings": {
      "schema": "src/settings.schema.json"
    },
    "resources": [
      {
        "id": "playerStreak",
        "path": "dist/visuals/player-streak.js",
        "type": "application/javascript",
        "visibility": "public",
        "metadata": {
          "role": "renderer-module",
          "moduleFormat": "esm",
          "defaultSize": [
            420,
            120
          ],
          "settingsSchema": "src/visuals/player-streak/settings.schema.json"
        }
      }
    ]
  }
}
