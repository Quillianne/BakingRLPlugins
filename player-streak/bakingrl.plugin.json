{
  "schemaVersion": "bakingrl.plugin/4",
  "bakingrlApi": "2.0.0",
  "id": "com.bakingrl.player-streak",
  "name": "PlayerStreak",
  "version": "1.0.5",
  "author": "BakingRL",
  "runtime": {
    "node": {
      "entry": "dist/extension/index.js"
    },
    "sidecars": []
  },
  "contributes": {
    "visuals": [
      {
        "id": "playerStreak",
        "entry": "dist/visuals/player-streak.js",
        "defaultSize": [420, 120],
        "instanceSettings": "src/visuals/player-streak/settings.schema.json"
      }
    ],
    "services": [
      {
        "id": "playerStreak",
        "runtime": "node",
        "methods": ["snapshot", "reset"],
        "schema": "src/services/player-streak/methods.schema.json"
      }
    ],
    "settings": {
      "schema": "src/settings.schema.json"
    }
  }
}
