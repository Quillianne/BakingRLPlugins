{
  "type": "object",
  "title": "Scoreboard Settings",
  "properties": {
    "theme": {
      "type": "string",
      "title": "Theme",
      "default": "app",
      "oneOf": [
        { "const": "app", "title": "App Theme" },
        { "const": "modern-dark", "title": "Modern Dark" },
        { "const": "neon-cyber", "title": "Neon Cyber" },
        { "const": "industrial-bakery", "title": "Industrial Bakery" },
        { "const": "pro-streamer", "title": "Pro Streamer" },
        { "const": "hacker-terminal", "title": "Hacker Terminal" },
        { "const": "broadcast-clean", "title": "Broadcast Clean" }
      ]
    },
    "showClock": {
      "type": "boolean",
      "title": "Show Match Clock",
      "default": true
    },
    "showBoWhenTracking": {
      "type": "boolean",
      "title": "Show BO Tracker",
      "default": true
    },
    "uppercaseNames": {
      "type": "boolean",
      "title": "Uppercase Team Names",
      "default": false
    }
  }
}
